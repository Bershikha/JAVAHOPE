class Solution {
    public String maximumOddBinaryNumber(String s) {
        int ones=0;
        for(char c:s.toCharArray()){
            if(c=='1')  ones++;
        }
        int zeroes=s.length()-ones;
        StringBuilder odd=new StringBuilder();
        for(int i=0;i<ones-1;i++){
            odd.append("1");
        }
        for(int j=0;j<zeroes;j++){
            odd.append("0");
        }
        odd.append("1");
        return odd.toString();
    }
}
